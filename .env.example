# AniBeam tracker credentials (build-time inlined via Vite envPrefix=ANIBEAM_).
#
# Copy this file to .env.local (gitignored via "*.local") and fill in real
# values to bundle them into your build. Distributed binaries built from a
# .env.local will ship with these credentials embedded — that's intended for
# release builds. Anyone building from source without .env.local will hit
# the per-user input fallback in the Trackers tab.
#
# Register apps here, redirect URL = http://127.0.0.1:53682/callback (exact):
#   AniList:  https://anilist.co/settings/developer
#   MAL:      https://myanimelist.net/apiconfig    (App Type: "Web")

# AniList implicit grant — only needs the numeric client_id.
ANIBEAM_ANILIST_CLIENT_ID=

# MAL PKCE — needs both. The "secret" is the long string from MAL's panel
# under "Issued Secret"; the id is the shorter hex blob under "Client ID".
ANIBEAM_MAL_CLIENT_ID=
ANIBEAM_MAL_CLIENT_SECRET=
