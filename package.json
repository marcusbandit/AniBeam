{
  "name": "anibeam",
  "private": true,
  "version": "1.0.0",
  "main": ".vite/build/main.js",
  "type": "module",
  "scripts": {
    "dev": "bun run typecheck && DEV_MODE=true electron-forge start",
    "build": "bun run typecheck && vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . && bun run typecheck",
    "verify:logger": "bun --bun scripts/verify-logger.mjs",
    "verify:motion": "bun --bun scripts/verify-motion.mjs",
    "verify:probe": "bun --bun scripts/verify-probe-parser.mjs",
    "verify:folder": "bun --bun scripts/verify-folder-wrapper.mjs",
    "verify:franchise-graph": "bun --bun scripts/verify-franchise-graph.mjs",
    "verify:franchise-crawler": "bun --bun scripts/verify-franchise-crawler.mjs",
    "verify:franchise-lanes": "bun --bun scripts/verify-franchise-lanes.mjs",
    "preview": "vite preview",
    "start": "bun run typecheck && electron-forge start",
    "package": "bun run typecheck && electron-forge package",
    "make": "bun run typecheck && electron-forge make"
  },
  "dependencies": {
    "@xyflow/react": "^12.10.2",
    "axios": "^1.13.2",
    "chokidar": "^5.0.0",
    "cli-progress": "^3.12.0",
    "dagre": "^0.8.5",
    "electron-squirrel-startup": "^1.0.1",
    "graphql": "^16.12.0",
    "graphql-request": "^7.3.5",
    "jassub": "^2.5.1",
    "lucide-react": "^0.561.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.10.1"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.10.2",
    "@electron-forge/maker-deb": "^7.10.2",
    "@electron-forge/maker-rpm": "^7.10.2",
    "@electron-forge/maker-squirrel": "^7.10.2",
    "@electron-forge/maker-zip": "^7.10.2",
    "@electron-forge/plugin-auto-unpack-natives": "^7.10.2",
    "@electron-forge/plugin-fuses": "^7.10.2",
    "@electron-forge/plugin-vite": "^7.10.2",
    "@electron/fuses": "^1.8.0",
    "@eslint/js": "^9.39.1",
    "@types/cli-progress": "^3.11.6",
    "@types/dagre": "^0.7.54",
    "@types/node": "^24.10.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "electron": "github:castlabs/electron-releases#v39.8.10+wvcus",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "extract-zip": "file:./vendor/extract-zip-shim",
    "globals": "^16.5.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.4"
  },
  "overrides": {
    "extract-zip": "file:./vendor/extract-zip-shim"
  }
}
